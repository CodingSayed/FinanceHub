@page
@model FinanceHub.Ui.Pages.TransactionsModel

@{
    ViewData["Title"] = "Transactions";
}

<h1 class="mb-4">Transactions</h1>

@if (!Model.Transactions.Any())
{
    <p>No transactions found.</p>
}
else
{
    @if (Model.Summary != null)
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Total Income</h5>
                    <p>@Model.Summary.TotalIncome</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Total Expenses</h5>
                    <p>@Model.Summary.TotalExpenses</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Net Balance</h5>
                    <p>@Model.Summary.NetBalance</p>
                </div>
            </div>
        </div>
    }
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Currency</th>
                <th>Source</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var transaction in Model.Transactions)
        {
            <tr>
                <td>@transaction.TransactionDate.ToString("yyyy-MM-dd")</td>
                <td>@transaction.Description</td>
                <td>@transaction.Amount</td>
                <td>@transaction.Currency</td>
                <td>@transaction.Source</td>
            </tr>
        }
        </tbody>
    </table>
}